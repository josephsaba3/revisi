OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low
OPENAI_ANALYSIS_PROMPT="Paste the private LLM analysis prompt here"

DATABASE_URL=sqlite:///./brand_voice_auditor.db
REQUEST_TIMEOUT_SECONDS=15
PUBLIC_SITE_URL=http://127.0.0.1:8000

SCAN_RATE_LIMIT_ENABLED=true
SCAN_RATE_LIMIT_COUNT=5
SCAN_RATE_LIMIT_WINDOW_SECONDS=600
