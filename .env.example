LLM_PROVIDER=openai
LLM_ANALYSIS_PROMPT="Paste the private LLM analysis prompt here"

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=12000
ANTHROPIC_EFFORT=medium
ANTHROPIC_PROMPT_CACHE_ENABLED=true
ANTHROPIC_OPENAI_FALLBACK_ENABLED=true

DATABASE_URL=sqlite:///./brand_voice_auditor.db
REQUEST_TIMEOUT_SECONDS=15
PUBLIC_SITE_URL=http://127.0.0.1:8000

FIRECRAWL_API_KEY=
FIRECRAWL_FALLBACK_ENABLED=true
FIRECRAWL_TIMEOUT_SECONDS=25
FIRECRAWL_MAX_CONCURRENCY=3
FIRECRAWL_MIN_EXTRACTED_LINES=6
FIRECRAWL_MIN_EXTRACTED_WORDS=80

SCAN_RATE_LIMIT_ENABLED=true
SCAN_RATE_LIMIT_COUNT=5
SCAN_RATE_LIMIT_WINDOW_SECONDS=600
